#!/usr/bin/env python3
"""
Minimal clang-format-compatible wrapper using GNU indent.
Supports typical formatter invocation styles used by VS Code extensions:
- custom-clang-format [options] <file>
- custom-clang-format [options]            (reads stdin, writes stdout)
"""

from __future__ import annotations

import os
import shutil
import subprocess
import sys
import tempfile


def run_indent(input_path: str, output_path: str) -> int:
    """Run GNU indent with a consistent C style suited for embedded projects."""
    cmd = [
        "indent",
        "-linux",
        "-i4",
        "-nut",
        "-l100",
        "-cli4",
        "-ppi4",
        "-npsl",
        input_path,
        "-o",
        output_path,
    ]
    proc = subprocess.run(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    return proc.returncode


def main() -> int:
    args = sys.argv[1:]

    in_place = "-i" in args

    # Pick the last positional argument as file path if present.
    file_arg = None
    for a in args:
        if a.startswith("-"):
            continue
        file_arg = a

    if file_arg and os.path.exists(file_arg):
        if in_place:
            with tempfile.NamedTemporaryFile(delete=False) as tf:
                temp_out = tf.name
            try:
                rc = run_indent(file_arg, temp_out)
                if rc != 0:
                    return 0
                shutil.move(temp_out, file_arg)
                return 0
            finally:
                if os.path.exists(temp_out):
                    os.unlink(temp_out)
        else:
            with tempfile.NamedTemporaryFile(delete=False) as tf:
                temp_out = tf.name
            try:
                rc = run_indent(file_arg, temp_out)
                if rc != 0:
                    with open(file_arg, "r", encoding="utf-8", errors="ignore") as f:
                        sys.stdout.write(f.read())
                    return 0
                with open(temp_out, "r", encoding="utf-8", errors="ignore") as f:
                    sys.stdout.write(f.read())
                return 0
            finally:
                if os.path.exists(temp_out):
                    os.unlink(temp_out)

    # Stdin mode
    src = sys.stdin.read()
    with tempfile.NamedTemporaryFile(delete=False, mode="w", encoding="utf-8") as in_tf:
        in_tf.write(src)
        temp_in = in_tf.name

    with tempfile.NamedTemporaryFile(delete=False) as out_tf:
        temp_out = out_tf.name

    try:
        rc = run_indent(temp_in, temp_out)
        if rc != 0:
            # Fail-soft: return input unchanged so formatting never breaks editing.
            sys.stdout.write(src)
            return 0

        with open(temp_out, "r", encoding="utf-8", errors="ignore") as f:
            sys.stdout.write(f.read())
        return 0
    finally:
        if os.path.exists(temp_in):
            os.unlink(temp_in)
        if os.path.exists(temp_out):
            os.unlink(temp_out)


if __name__ == "__main__":
    raise SystemExit(main())
